# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
/logs/

# local env files
.env*.local
.env
.env.backup

# diagnostic and test files with secrets
test-whisk*.js
diagnostic-data/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# electron
/electron/dist/
/dist/
/dist-portable/

# playwright and browser automation
playwright-data/
playwright-chrome-*/
/tmp/

# large media files (avatars stored locally, not in git)
public/avatars/*.mp4
*.mp4

# FFmpeg binaries (too large for git)
resources/bin/windows/*.exe
resources/bin/macos/ffmpeg
resources/bin/macos/ffprobe
resources/bin/linux/ffmpeg
resources/bin/linux/ffprobe

# Keep directory structure
!resources/bin/**/.gitkeep

# Temporary FFmpeg download files
temp-ffmpeg/

# Node.js portable runtime (large binary, download separately)
/resources/node/*
!/resources/node/.gitkeep

# Ignore ZIP downloads
*.zip
