# Test Environment Variables
# CRITICAL: This file ensures tests use a separate database to avoid corrupting production data

# Database Configuration (separate test database)
DATABASE_URL=postgresql://obsidian:obsidian_password@localhost:5432/obsidian_news_test
REDIS_URL=redis://localhost:6379/1

# Environment
NODE_ENV=test

# API Keys (test values - will be mocked via MSW)
OPENAI_API_KEY=test-openai-key
ANTHROPIC_API_KEY=test-anthropic-key
GOOGLE_API_KEY=test-google-key
GROQ_API_KEY=test-groq-key
WHISK_API_TOKEN=test-whisk-token

# AI Provider (default for tests)
AI_PROVIDER=openai

# Admin API Key
ADMIN_API_KEY=test-admin-key-12345

# Storage Paths (test directories)
STORAGE_PATH=C:\Users\konra\ObsidianNewsDesk\test
LOCAL_STORAGE_ROOT=C:\Users\konra\ObsidianNewsDesk\test

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8347

# Disable external services during tests
ENABLE_TELEMETRY=false
