# Test Environment Variables
# Copy from .env and modify as needed for testing

NODE_ENV=test
NEXT_PUBLIC_APP_URL=http://localhost:8347

# Test Database (use separate DB to avoid data corruption)
DATABASE_URL=postgresql://obsidian:obsidian_password@localhost:5432/obsidian_news_test

# Redis (same instance OK for tests, different key prefix handled in code)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=obsidian_redis_password

# Local Storage (use separate directory for tests)
LOCAL_STORAGE_ROOT=C:\Users\konra\ObsidianNewsDesk\test

# AI Providers (use real keys or mocks)
AI_PROVIDER=openai
OPENAI_API_KEY=test_key_replace_with_real_if_needed

# Whisk API (use mock or real token)
WHISK_API_TOKEN=test_token_replace_with_real_if_needed

# Admin API Key
ADMIN_API_KEY=test_admin_key_for_testing

# Remotion
REMOTION_TIMEOUT_MS=60000
REMOTION_CONCURRENCY=1
