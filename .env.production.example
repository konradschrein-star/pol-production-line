# ================================
# Production Environment Template
# Obsidian News Desk Automation Pipeline
# ================================
#
# Copy this file to .env and fill in all values before deploying.
# IMPORTANT: Never commit .env files to version control!
#
# Security Notes:
# - Use strong, unique passwords (20+ characters)
# - Rotate API keys regularly
# - Store secrets in a secure vault (AWS Secrets Manager, etc.)
# - Use environment-specific values (dev, staging, prod)

# ================================
# Application Configuration
# ================================

# Environment mode (production for deployments)
NODE_ENV=production

# Public URL of your application (used for CORS, redirects, etc.)
# Examples:
#   - Railway: https://your-app.up.railway.app
#   - VPS: https://yourdomain.com
#   - Local: http://localhost:8347
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Application port (default: 8347)
# Note: Railway and some PaaS platforms override this
PORT=8347

# ================================
# Database Configuration
# ================================

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
#
# Docker Compose: Use internal service name "postgres"
# DATABASE_URL=postgresql://obsidian:YOUR_STRONG_PASSWORD@postgres:5432/obsidian_news
#
# Railway: Automatically populated by Railway PostgreSQL service
# DATABASE_URL=${RAILWAY_POSTGRESQL_URL}
#
# External Database (RDS, DigitalOcean, etc.):
# DATABASE_URL=postgresql://username:password@db.example.com:5432/obsidian_news
DATABASE_URL=postgresql://obsidian:YOUR_STRONG_PASSWORD@postgres:5432/obsidian_news

# Docker Compose Only - Database credentials
POSTGRES_USER=obsidian
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD
POSTGRES_DB=obsidian_news

# ================================
# Redis Configuration
# ================================

# Redis connection (for BullMQ queues)
#
# Docker Compose: Use internal service name "redis"
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_STRONG_PASSWORD

# Railway: If using Railway Redis, set:
# REDIS_HOST=${RAILWAY_REDIS_HOST}
# REDIS_PORT=${RAILWAY_REDIS_PORT}
# REDIS_PASSWORD=${RAILWAY_REDIS_PASSWORD}

# ================================
# AI Providers
# ================================

# Active AI provider for script analysis
# Options: openai | claude | google | groq
AI_PROVIDER=openai

# OpenAI API Key (required if AI_PROVIDER=openai)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Anthropic Claude API Key (required if AI_PROVIDER=claude)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google AI API Key (required if AI_PROVIDER=google)
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=AIza...

# Groq API Key (required if AI_PROVIDER=groq)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ================================
# Google Whisk (Image Generation)
# ================================

# REQUIRED: Google Whisk Bearer token
# How to get:
#   1. Open https://labs.google.com/whisk in Chrome
#   2. Open DevTools (F12) → Network tab
#   3. Generate a test image in Whisk
#   4. Find "generateImage" request
#   5. Copy entire Authorization header value (starts with "Bearer ")
WHISK_API_TOKEN=Bearer ya29.a0...

# Image model version
# Options: IMAGEN_3_5 | IMAGEN_4
WHISK_IMAGE_MODEL=IMAGEN_3_5

# Performance tuning - concurrent image generation
# Default: 2 parallel generations, scales to 5 under load
WHISK_CONCURRENCY=2
WHISK_MIN_CONCURRENCY=2
WHISK_MAX_CONCURRENCY=5

# ================================
# Browser Automation (Playwright)
# ================================

# Auto Whisk Chrome Extension ID (for automated image generation)
# Default: Official Chrome Web Store extension
AUTO_WHISK_EXTENSION_ID=gedfnhdibkfgacmkbjgpfjihacalnlpn

# Default browser for Playwright
# Options: chrome | edge | chromium
DEFAULT_BROWSER=chrome

# Custom browser executable path (optional)
# Leave empty to use system default
# Examples:
#   - Windows: C:/Program Files/Google/Chrome/Application/chrome.exe
#   - Linux: /usr/bin/chromium-browser
#   - macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
BROWSER_EXECUTABLE_PATH=

# Persistent browser profile directory (saves Google login)
# Relative to project root or absolute path
PLAYWRIGHT_USER_DATA_DIR=./playwright-data

# ================================
# HeyGen Avatar Generation
# ================================

# Audio sample rate for HeyGen (must be 48000 Hz)
HEYGEN_AUDIO_SAMPLE_RATE=48000

# Avatar generation mode
# Options:
#   - manual: Launch browser manually, user generates avatar in HeyGen UI
#   - automated: Python automation handles everything (requires setup)
AVATAR_MODE=manual

# Python Automation Settings (only needed if AVATAR_MODE=automated)
# See: HEYGEN_AUTOMATION_SETUP.md for full setup guide

# Path to HeyGen Chrome profile (created by setup script)
HEYGEN_PROFILE_PATH=./integrations/heygen-automation/heygen-chrome-profile

# Python executable path
# Try: python | python3 | /usr/bin/python3 | C:\Python39\python.exe
PYTHON_EXECUTABLE=python3

# ================================
# Remotion Video Rendering
# ================================

# Maximum rendering timeout in milliseconds
# Default: 300000 (5 minutes)
# Increase for long videos or slow hardware
REMOTION_TIMEOUT_MS=300000

# Number of parallel rendering threads
# Default: 4
# Adjust based on available CPU cores
# Note: Higher values increase memory usage
REMOTION_CONCURRENCY=4

# Remotion bundle cache directory (speeds up subsequent renders)
# Relative to project root or absolute path
REMOTION_BUNDLE_CACHE_DIR=./tmp/remotion-cache

# ================================
# Storage Configuration
# ================================

# Local File Storage
# Files are stored locally on disk:
#   - storage/images/ - Scene background images
#   - storage/avatars/ - HeyGen avatar MP4 files
#   - storage/videos/ - Final rendered videos
#
# For production deployments:
# - Docker: Use named volumes (configured in docker-compose.production.yml)
# - Railway: Use persistent storage or external storage (S3, R2)
# - VPS: Ensure sufficient disk space (100GB+ recommended)
#
# Future: Cloudflare R2 or AWS S3 integration (optional)

# ================================
# Security & Performance
# ================================

# Node.js memory limit (optional)
# Increase if experiencing out-of-memory errors
# Examples: --max-old-space-size=4096 (4GB), --max-old-space-size=8192 (8GB)
# NODE_OPTIONS=--max-old-space-size=4096

# Disable Next.js telemetry (optional)
NEXT_TELEMETRY_DISABLED=1

# ================================
# Optional: Logging & Monitoring
# ================================

# Log level (optional)
# Options: error | warn | info | debug
# LOG_LEVEL=info

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://...@sentry.io/...

# ================================
# Optional: External Services
# ================================

# SMTP for email notifications (future feature)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG...

# Webhook URL for job completion notifications (future feature)
# WEBHOOK_URL=https://example.com/webhook
