# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Local Postgres via Docker)
DATABASE_URL=postgresql://obsidian:obsidian_password@localhost:5432/obsidian_news

# Redis (Local via Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=obsidian_redis_password

# Local Storage (Replaced R2)
# Files are stored locally at: C:\Users\konra\ObsidianNewsDesk\
# - images/ - Scene background images
# - avatars/ - HeyGen avatar MP4 files
# - videos/ - Final rendered videos
# No configuration needed - directories auto-created on startup

# AI Providers
AI_PROVIDER=claude  # Options: claude | google | groq
ANTHROPIC_API_KEY=your_key_here
GOOGLE_AI_API_KEY=your_key_here
GROQ_API_KEY=your_key_here

# Playwright Browser Automation
# Auto Whisk Chrome Extension ID
# From: https://chromewebstore.google.com/detail/auto-whisk-nano-banana-im/gedfnhdibkfgacmkbjgpfjihacalnlpn
AUTO_WHISK_EXTENSION_ID=gedfnhdibkfgacmkbjgpfjihacalnlpn

# Browser executable (optional - uses system default if blank)
BROWSER_EXECUTABLE_PATH=

# Default browser type (chrome | edge | chromium)
DEFAULT_BROWSER=edge

# Persistent context directory (saves Google login)
PLAYWRIGHT_USER_DATA_DIR=./playwright-data

# HeyGen Configuration
HEYGEN_AUDIO_SAMPLE_RATE=48000

# Remotion
REMOTION_TIMEOUT_MS=300000
REMOTION_CONCURRENCY=2
