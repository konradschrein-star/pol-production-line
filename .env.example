# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:8347

# Database (Local Postgres via Docker)
DATABASE_URL=postgresql://obsidian:obsidian_password@localhost:5432/obsidian_news

# Redis (Local via Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=obsidian_redis_password

# Local File Storage (R2 cloud storage not used)
# ============================================
# Storage directory for all assets (images, avatars, videos, footage)
#
# AUTO-DETECTION: Leave blank to use default location
#   Windows: %USERPROFILE%\ObsidianNewsDesk  (e.g., C:\Users\YourName\ObsidianNewsDesk)
#   Mac/Linux: ~/ObsidianNewsDesk
#
# CUSTOM PATH: Set explicit path if you want to use a different location
#   Example: D:\MyVideos\ObsidianNewsDesk
#   Example: E:\Projects\NewsVideos
#
# The system will auto-create these subdirectories:
#   images/    Scene background images (generated by Whisk API)
#   avatars/   HeyGen avatar MP4 files
#   videos/    Final rendered videos
#   footage/   Stock video footage (from Pexels API)
#   temp/      Temporary render files (auto-cleaned)
#
LOCAL_STORAGE_ROOT=

# AI Providers
AI_PROVIDER=openai  # Options: openai | claude | google | groq

# Scene-Based Image Generation (Phase 2)
# When enabled, AI generates images using scene-based context with sentence-level mapping
# - Groups sentences into 4-7 sentence "scenes" for contextual understanding
# - Generates N prompts per scene (one per sentence) with shared visual theme
# - Produces 30-50 images for better coverage vs old 10-15 topic-based approach
# - Includes detailed photography specs (camera, lens, lighting) for realism
# See: docs/SCENE_BASED_GENERATION.md
SCENE_BASED_ANALYSIS=true  # Options: true | false (default: false for backward compatibility)

# IMPORTANT: Replace these placeholder values with your actual API keys
# Never commit .env file to git - only commit .env.example
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
GOOGLE_AI_API_KEY=your_google_ai_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Whisk API Configuration (Direct API - No Browser Automation Needed!)
# Get your token: Open https://labs.google.com/whisk → F12 → Network → Generate image → Copy Authorization Bearer token
# See: docs/WHISK_TOKEN_SETUP.md
# Token format: ya29.a0ATkoCc... (starts with ya29, expires after ~1 hour)
WHISK_API_TOKEN=ya29.your_whisk_api_token_here

# ✅ NEW: Custom API endpoint (optional - defaults to Google's endpoint)
# Only change this if you're using a proxy or custom implementation
# WHISK_API_ENDPOINT=https://aisandbox-pa.googleapis.com/v1/whisk:generateImage

# Automatic Token Refresh Configuration
# System automatically refreshes expired tokens using Chrome profile
WHISK_TOKEN_REFRESH_ENABLED=true          # Enable/disable automatic token refresh
WHISK_TOKEN_REFRESH_HEADLESS=true         # Run browser in headless mode (no visible window)
WHISK_TOKEN_REFRESH_TIMEOUT=30000         # Browser automation timeout in milliseconds (30s default)
CHROME_PROFILE_PATH=                       # Optional: Override default Chrome profile location
                                           # Default: Auto-detected from system (Windows: %LOCALAPPDATA%\Google\Chrome\User Data)

# ============================================
# SECURITY CONFIGURATION
# ============================================

# API Authentication Key (REQUIRED)
# Used to authenticate ALL API requests via Authorization: Bearer <API_KEY> header
# Generate a secure random key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: This must be set or all API requests will be rejected
API_KEY=your_secure_random_64_char_api_key_here

# Admin API Key (for settings endpoint protection)
# Generate a secure random 32-character string
ADMIN_API_KEY=your_secure_random_32_char_admin_key

# Legacy: Browser Automation (DEPRECATED - Use API instead)
# Auto Whisk Chrome Extension ID
AUTO_WHISK_EXTENSION_ID=gcgblhgncmhjchllkcpcneeibddhmbbe

# Browser executable (optional - uses system default if blank)
BROWSER_EXECUTABLE_PATH=

# Default browser type (chrome | edge | chromium)
DEFAULT_BROWSER=edge

# Persistent context directory (NOT USED - we use CDP instead)
PLAYWRIGHT_USER_DATA_DIR=

# HeyGen Configuration
AVATAR_MODE=manual  # Options: manual | automated
HEYGEN_AUDIO_SAMPLE_RATE=48000

# Remotion
REMOTION_TIMEOUT_MS=300000
REMOTION_CONCURRENCY=2

# ============================================
# PEXELS VIDEO API CONFIGURATION (Phase 1)
# ============================================

# Pexels API Key (required for video footage mode)
# Get your free API key: https://www.pexels.com/api/
# Free tier limits: 200 requests/hour, 20,000/month
PEXELS_API_KEY=your_pexels_api_key_here

# Video footage storage directory (optional)
# Defaults to: {LOCAL_STORAGE_ROOT}/footage
# Leave commented to use auto-detected default
# FOOTAGE_STORAGE_DIR=

# Whisk Locale (de, en, fr, etc.)
WHISK_LOCALE=de
